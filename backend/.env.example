# ── Autonomous Content Factory — API Keys ──────────────────
# Fill in ONE or more keys. Restart the backend after editing.
# Set DEFAULT_PROVIDER to whichever key you've filled in.

# Google Gemini (free) → https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# Anthropic Claude → https://console.anthropic.com/settings/api-keys
ANTHROPIC_API_KEY=

# OpenAI → https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Which provider to use by default: gemini | claude | openai
DEFAULT_PROVIDER=gemini
